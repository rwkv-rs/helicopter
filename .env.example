# Keep this file in simple dotenv syntax: KEY=VALUE or export KEY=VALUE.
# Do not use shell expressions if the Python CLI must read the same file.
REMOTE_SSH_HOST=rwkv-sha-pro6000x8
REMOTE_ROOT=/home/<user>/Projects/MachineLearning/helicopter
REMOTE_VENV=/home/<user>/Projects/MachineLearning/helicopter/.venv
REMOTE_CUDA_HOME=/usr/local/cuda
VLLM_BUILD_PROFILE=rwkv
PYTHON_VERSION=3.12
INSTALL_COMPONENTS=rwkv-lm,dev
UPDATE_UV=0
UV_UPGRADE=0
RUN_PIP_CHECK=1
UV_SYNC_INEXACT=1
VLLM_TARGET_DEVICE=cuda
VLLM_VERSION_OVERRIDE=0.11.2.dev278+gdbc3d9991
VLLM_USE_PRECOMPILED=0
VLLM_REBUILD=auto
VERL_REINSTALL=auto
CMAKE_BUILD_TYPE=RelWithDebInfo
BUILD_TMPDIR=/home/<user>/Projects/MachineLearning/helicopter/.tmp
REMOTE_HTTP_PROXY=
REMOTE_HTTPS_PROXY=
REMOTE_NO_PROXY=localhost,127.0.0.1,::1
REMOTE_REQUIRED_DIRS="/home/<user>/Projects /home/<user>/Weights /home/<user>/Datasets"
REMOTE_RUN_LOG_DIR=logs/remote
REMOTE_COLLECT_PATHS="logs reports/validation outputs runs wandb tensorboard"
PYPI_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
HF_ENDPOINT=https://hf-mirror.com
UV_LINK_MODE=copy
CARGO_REGISTRY_MIRROR=sparse+https://rsproxy.cn/index/
SYNC_REMOTE=1
INSTALL_REMOTE=1

HELICOPTER_VENV=/home/<user>/Projects/MachineLearning/helicopter/.venv
HELICOPTER_VERL_PATH=src/train/verl-rwkv
RWKV_LM_PATH=src/train/rwkv-lm
HELICOPTER_VLLM_RWKV_PATH=src/infer/vllm-rwkv

WEIGHT_PATH=/home/<user>/Weights/RWKV
DATASETS_PATH=/home/<user>/Datasets

HELICOPTER_NUM_NODES=1
HELICOPTER_NUM_DEVICES=8

HELICOPTER_TAKEOFF_WKV_MODE=fp32io16
HELICOPTER_TAKEOFF_EMB_DEVICE=gpu
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
