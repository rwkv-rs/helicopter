# Keep this file in simple dotenv syntax: KEY=VALUE or export KEY=VALUE.
# Do not use shell expressions if the Python CLI must read the same file.
REMOTE_WORKSPACE_ID=g6
REMOTE_NAMESPACE=devpod
REMOTE_POD=devpod-default-g6-xxxx
REMOTE_NODE=g6
REMOTE_IMAGE=mirrors.bbt.sspu.edu.cn:8081/sspu/bbt-devpod-ubuntu24-cuda:YYYYMMDD
DEVPOD_SEED_IMAGE=nvcr.io/nvidia/cuda:13.2.1-cudnn-devel-ubuntu24.04
DEVPOD_HOME=/home/<user>/.devpod
DEVPOD_SOURCE=/home/<user>/.devpod/manual-sources/g6
DEVPOD_POD_TEMPLATE=/home/<user>/.devpod/manual-sources/bbt-devpod-shared-mount-template.yaml
REMOTE_SSH_HOST=g6.devpod
REMOTE_ROOT=/workspace/Projects/MachineLearning/helicopter
REMOTE_VENV=/workspace/Projects/MachineLearning/helicopter/.venv
PYTHON_VERSION=3.12
INSTALL_PROFILE=rwkv
UPDATE_UV=0
UV_UPGRADE=0
RUN_PIP_CHECK=1
UV_SYNC_INEXACT=1
VLLM_TARGET_DEVICE=cuda
VLLM_VERSION_OVERRIDE=0.11.2.dev278+gdbc3d9991
VLLM_USE_PRECOMPILED=0
VLLM_REBUILD=auto
VERL_REINSTALL=auto
CMAKE_BUILD_TYPE=RelWithDebInfo
BUILD_TMPDIR=/workspace/Projects/MachineLearning/helicopter/.tmp
REMOTE_HTTP_PROXY=http://192.168.122.1:10810
REMOTE_HTTPS_PROXY=http://192.168.122.1:10810
REMOTE_NO_PROXY=localhost,127.0.0.1,::1,.svc,.cluster.local,.bbt.sspu.edu.cn,10.0.0.0/8,192.168.0.0/16
PYPI_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
HF_ENDPOINT=https://hf-mirror.com
UV_LINK_MODE=copy
CARGO_REGISTRY_MIRROR=sparse+https://rsproxy.cn/index/
DEVPOD_RECREATE=0
SYNC_REMOTE=1
INSTALL_REMOTE=1

HELICOPTER_VENV=/workspace/Projects/MachineLearning/helicopter/.venv
HELICOPTER_VERL_PATH=src/train/verl-rwkv
RWKV_LM_PATH=src/train/rwkv-lm
VLLM_RWKV_PATH=src/infer/vllm-rwkv

WEIGHT_PATH=/workspace/Weights/RWKV
DATASETS_PATH=/workspace/Datasets

VLLM_HOST=127.0.0.1
VLLM_PORT=8000
HELICOPTER_NUM_NODES=1
HELICOPTER_NUM_DEVICES=8
VLLM_TENSOR_PARALLEL_SIZE=1

HELICOPTER_INFER_WKV_MODE=fp16
HELICOPTER_INFER_EMB_DEVICE=gpu
HELICOPTER_TAKEOFF_WKV_MODE=fp32io16
HELICOPTER_TAKEOFF_EMB_DEVICE=cpu
VLLM_USE_V2_MODEL_RUNNER=1
VLLM_RWKV7_RKV_MODE=off
VLLM_RWKV7_CMIX_SPARSE=no-fc
VLLM_RWKV7_LOW_RANK_WEIGHT=both

VLLM_GPU_MEMORY_UTILIZATION=0.85
VLLM_MAX_NUM_SEQS=2048
VLLM_MAX_NUM_BATCHED_TOKENS=65536
